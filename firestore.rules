rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders collection - authenticated users can create and read their own orders
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || request.auth.token.email == resource.data.userEmail);
      allow update, delete: if false; // Only admin/backend can modify
    }
  }
}
