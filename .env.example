# Environment Configuration
NODE_ENV=development

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENVIRONMENT=development

# Backend
PORT=5000
MONGODB_URI=mongodb://admin:admin123@localhost:27017/xerox_db?authSource=admin

# JWT Configuration
JWT_SECRET=your_very_secure_secret_key_change_this_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# Email Configuration (Gmail/SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@xeroxcenter.com

# File Upload Configuration
MAX_FILE_SIZE=50000000  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,docx,pptx,jpg,jpeg,png,txt
UPLOAD_DIRECTORY=./uploads

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=xerox-center-uploads

# Payment Gateway Configuration
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe (Alternative)
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Integration (Twilio)
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id
WHATSAPP_PHONE_NUMBER=+1234567890

# Admin Configuration
ADMIN_EMAIL=admin@xeroxcenter.com
ADMIN_PASSWORD=admin_password_here  # Change this!

# App Configuration
APP_NAME=Smart Xerox Center
APP_URL=https://xeroxcenter.com
SUPPORT_EMAIL=support@xeroxcenter.com
SUPPORT_PHONE=+91-XXXXXXXXXX

# Analytics (Google Analytics)
GOOGLE_ANALYTICS_ID=UA-XXXXXXX-X

# Database Backup
BACKUP_FREQUENCY=daily  # daily, weekly, monthly
BACKUP_RETENTION_DAYS=30

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
SESSION_SECRET=your_session_secret_key_here
