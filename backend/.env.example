# Backend API .env Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://admin:admin123@localhost:27017/xerox_db?authSource=admin

# JWT Configuration
JWT_SECRET=your_very_secure_secret_key_change_this_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@xeroxcenter.com

# File Upload
MAX_FILE_SIZE=50000000
ALLOWED_FILE_TYPES=pdf,docx,pptx,jpg,jpeg,png,txt
UPLOAD_DIRECTORY=./uploads

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# SMS - Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin Setup
ADMIN_EMAIL=admin@xeroxcenter.com
ADMIN_PASSWORD=admin_password_here

# Firebase Admin SDK Configuration (for token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

